# Optional: when set, SecureFlow uses PostgreSQL instead of in-memory storage.
# Example (Docker): docker run -d --name sf-pg -e POSTGRES_USER=secureflow -e POSTGRES_PASSWORD=secureflow -e POSTGRES_DB=secureflow -p 5432:5432 postgres:16
# DATABASE_URL=postgresql://secureflow:secureflow@localhost:5432/secureflow

PORT=4000

# UTF-8 text export of all tickets (readable in Notepad). Default: <server cwd>/data/tickets-notepad.txt
# TICKETS_NOTEPAD_PATH=C:\\path\\to\\tickets-notepad.txt
